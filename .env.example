# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Generation backend:
#   anthropic — call the Claude API (requires ANTHROPIC_API_KEY below)
#   local     — offline extractive answers from retrieved context (NO API key needed)
#   hf        — a small LLM downloaded to disk, run on this machine (NO API key needed;
#               requires `pip install torch transformers accelerate` + the model files)
RAG_BACKEND=anthropic

# Required only when RAG_BACKEND=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override the default model
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional: generation tuning
RAG_MAX_TOKENS=600
RAG_TEMPERATURE=0.0
RAG_REQUEST_TIMEOUT=30
RAG_MAX_RETRIES=3

# Optional: retrieval tuning
RAG_TOP_K=5
RAG_MAX_PER_SOURCE=2
RAG_MIN_SCORE=0.01
RAG_CHUNK_SIZE=700

# Optional: local backend refuses when top retrieval score is below this
RAG_LOCAL_MIN_CONFIDENCE=0.12

# Optional: on-device local LLM (RAG_BACKEND=hf)
RAG_HF_MODEL_DIR=models/Qwen2.5-1.5B-Instruct
RAG_HF_MAX_NEW_TOKENS=400

# Optional: logging level (DEBUG, INFO, WARNING, ERROR)
RAG_LOG_LEVEL=INFO
